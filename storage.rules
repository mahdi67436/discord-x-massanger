rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ============== HELPER FUNCTIONS ==============
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidFileType(type, allowedTypes) {
      return type in allowedTypes;
    }
    
    function isValidFileSize(size, maxSize) {
      return size <= maxSize;
    }
    
    // ============== USER FILES ==============
    
    // User avatars
    match /users/{userId}/avatars/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId)
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/gif', 'image/webp'])
        && isValidFileSize(request.resource.size, 5 * 1024 * 1024); // 5MB
    }
    
    // User banners
    match /users/{userId}/banners/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId)
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/gif', 'image/webp'])
        && isValidFileSize(request.resource.size, 10 * 1024 * 1024); // 10MB
    }
    
    // ============== SERVER FILES ==============
    
    // Server icons
    match /servers/{serverId}/icons/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/servers/$(serverId)/ownerId)
        && request.auth.uid == get(/databases/$(database)/documents/servers/$(serverId)).data.ownerId
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/gif', 'image/webp'])
        && isValidFileSize(request.resource.size, 10 * 1024 * 1024);
    }
    
    // Server banners
    match /servers/{serverId}/banners/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/servers/$(serverId)/ownerId)
        && request.auth.uid == get(/databases/$(database)/documents/servers/$(serverId)).data.ownerId
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/gif', 'image/webp'])
        && isValidFileSize(request.resource.size, 20 * 1024 * 1024);
    }
    
    // Server emojis
    match /servers/{serverId}/emojis/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/servers/$(serverId)/roles/$(request.auth.uid))
        && isValidFileType(request.resource.contentType, ['image/png', 'image/gif'])
        && isValidFileSize(request.resource.size, 256 * 1024); // 256KB
    }
    
    // Server stickers
    match /servers/{serverId}/stickers/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/servers/$(serverId)/roles/$(request.auth.uid))
        && isValidFileType(request.resource.contentType, ['image/png', 'image/apng', 'image/gif', 'image/lottie'])
        && isValidFileSize(request.resource.size, 512 * 1024); // 512KB
    }
    
    // ============== MESSAGE FILES ==============
    
    // Message attachments
    match /messages/{messageId}/attachments/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isValidFileType(request.resource.contentType, [
            'image/jpeg', 'image/png', 'image/gif', 'image/webp',
            'video/mp4', 'video/webm', 'video/quicktime',
            'audio/mpeg', 'audio/wav', 'audio/ogg',
            'application/pdf',
            'application/zip', 'application/x-rar-compressed',
            'text/plain', 'text/csv', 'text/json',
            'application/msword',
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
            'application/vnd.ms-excel',
            'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
          ])
        && isValidFileSize(request.resource.size, 100 * 1024 * 1024); // 100MB
    }
    
    // Message images
    match /messages/{messageId}/images/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/gif', 'image/webp'])
        && isValidFileSize(request.resource.size, 20 * 1024 * 1024); // 20MB
    }
    
    // Voice messages
    match /messages/{messageId}/voice/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isValidFileType(request.resource.contentType, ['audio/mpeg', 'audio/wav', 'audio/ogg', 'audio/webm'])
        && isValidFileSize(request.resource.size, 10 * 1024 * 1024); // 10MB
    }
    
    // ============== ORGANIZATION FILES ==============
    
    // Organization logos
    match /organizations/{orgId}/logos/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/admins/$(request.auth.uid))
        && isValidFileType(request.resource.contentType, ['image/jpeg', 'image/png', 'image/svg+xml'])
        && isValidFileSize(request.resource.size, 5 * 1024 * 1024);
    }
    
    // Organization documents
    match /organizations/{orgId}/documents/{fileName} {
      allow read: if isAuthenticated()
        && orgId in request.auth.token.organizations;
      allow write: if isAuthenticated()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/admins/$(request.auth.uid))
        && isValidFileSize(request.resource.size, 100 * 1024 * 1024);
    }
    
    // ============== CALL RECORDINGS ==============
    
    // Call recordings
    match /calls/{callId}/recordings/{fileName} {
      allow read: if isAuthenticated()
        && exists(/databases/$(database)/documents/calls/$(callId)/participants/$(request.auth.uid));
      allow write: if isAuthenticated()
        && isValidFileType(request.resource.contentType, ['video/mp4', 'video/webm'])
        && isValidFileSize(request.resource.size, 1024 * 1024 * 1024); // 1GB
    }
    
    // ============== BACKUPS ==============
    
    // User backups
    match /backups/{backupId}/{fileName} {
      allow read: if isOwner(backupId);
      allow write: if isOwner(backupId)
        && isValidFileSize(request.resource.size, 5 * 1024 * 1024 * 1024); // 5GB
    }
    
    // ============== TEMPORARY FILES ==============
    
    // Temporary uploads (should be cleaned up by Cloud Functions)
    match /temp/{fileName} {
      allow read, write: if false; // No direct access, use Cloud Functions
    }
  }
}
